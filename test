namespace App\Http\Controllers;

use App\Models\Estudiante;
use Illuminate\Http\Request;
use App\Models\Materia;

class EstudianteController extends Controller
{
    public function index(Request $request)
    {
        $query = Estudiante::query();
        $materias = Materia::all();

        if ($request->filled('SearchNombre')) {
            $query->where('EST_NOM', $request->SearchNombre);
        }

        if ($request->filled('SearchCedula')) {
            $query->where('EST_CED', $request->SearchCedula);
        }

        $estudiantes = $query->get();

        return view('estudiantes', compact('estudiantes', 'materias'));
    }

    public function store(Request $request)
    {
        $request->validate([
            'txtCedula' => 'required|string|max:10|unique:Estudiantes,EST_CED',
            'txtNombre' => 'required|string|max:100',
            'txtApellido' => 'required|string|max:100',
            'txtDireccion' => 'required|string|max:200',
            'txtTelefono' => 'required|string|max:15',
        ]);

        Estudiante::create([
            'EST_CED' => $request->txtCedula,
            'EST_NOM' => $request->txtNombre,
            'EST_APE' => $request->txtApellido,
            'EST_DIR' => $request->txtDireccion,
            'EST_TEL' => $request->txtTelefono
        ]);

        return redirect()->route('index')->with('success', 'Estudiante agregado correctamente');
    }

    public function update(Request $request)
    {
        $request->validate([
            'txtCedula' => 'required|string|max:10',
            'txtNombre' => 'required|string|max:100',
            'txtApellido' => 'required|string|max:100',
            'txtDireccion' => 'required|string|max:200',
            'txtTelefono' => 'required|string|max:15',
        ]);

        $estudiante = Estudiante::findOrFail($request->txtCedula);

        $estudiante->update([
            'EST_CED' => $request->txtCedula,
            'EST_NOM' => $request->txtNombre,
            'EST_APE' => $request->txtApellido,
            'EST_DIR' => $request->txtDireccion,
            'EST_TEL' => $request->txtTelefono
        ]);

        return redirect()->route('index')->with('success', 'Estudiante actualizado correctamente');
    }

    public function destroy(Request $request)
    {
        $estudiante = Estudiante::findOrFail($request->txtCedula);

        if (Materia::where('ID_EST_INS', $request->txtCedula)->exists()) {
            return redirect()->route('index')
                ->with('error', 'No se puede eliminar el estudiante porque tiene materias asociadas.');
        }

        $estudiante->delete();

        return redirect()->route('index')->with('success', 'Estudiante eliminado correctamente');
    }
}
