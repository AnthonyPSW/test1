class ControllerPeliculas extends Controller
{
    /**
     * Display a listing of the resource.
     */
    public function index(Request $request)
    {
        $generos = Genero::all();
        
        $query = Peliculas::query();

        if ($request->filled('buscar_titulo')) {
            $query->where('TIT_PEL', 'like', '%' . $request->buscar_titulo . '%');
        }

        if ($request->filled('buscar_director')) {
            $query->where('DIR_PEL', 'like', '%' . $request->buscar_director . '%');
        }

        if ($request->filled('buscar_genero')) {
            $query->where('ID_GEN_PER', $request->buscar_genero);
        }

        $peliculas = $query->get();

        return view('index', compact('generos', 'peliculas'));
    }

    /**
     * Store a newly created resource in storage.
     */
    public function store(Request $request)
    {
        $data=Peliculas::create([
            "TIT_PEL"=>$request->txtNombre,
            "ANIO_PEL"=>$request->txtAnio,
            "DIR_PEL"=>$request->txtDirector,
            "DIS_PEL"=>$request->txtDisponi,
            "ID_GEN_PER"=>$request->txtGenero
        ]);
        return redirect()->route('peliculas.index');
        
    }

    /**
     * Display the specified resource.
     */
    public function show(string $id)
    {
        //
    }

    /**
     * Update the specified resource in storage.
     */
    public function update(Request $request, string $id)
    {
        $pelicula = Peliculas::where('ID_PEL', $id)->firstOrFail();
        $pelicula->update([
            "TIT_PEL"=>$request->txtNombre,
            "ANIO_PEL"=>$request->txtAnio,
            "DIR_PEL"=>$request->txtDirector,
            "DIS_PEL"=>$request->has('txtDisponi') ? 1 : 0,
            "ID_GEN_PER"=>$request->txtGenero
        ]);
        return redirect()->route('peliculas.index');
    }

    /**
     * Remove the specified resource from storage.
     */
    public function destroy(string $idPel)
    {
        $pelicula=Peliculas::where('ID_PEL', $idPel)->firstOrFail();
        $pelicula->delete();
        return redirect()->route('peliculas.index');
        //
    }
}
